# Server
PORT=3000

# Auth — use a strong random string, e.g.: openssl rand -hex 32
JWT_SECRET=your-secret-here

# Gmail SMTP (2FA + App Password required)
# Create app password: Google Account → Security → App passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional
# DB_PATH=./data/timecapsule.db
# DELIVERY_INTERVAL_MS=30000
# LOG_DIR=./logs
