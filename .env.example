# Server
PORT=3000

# Auth — use a strong random string, e.g.: openssl rand -hex 32
JWT_SECRET=your-secret-here

# Resend (https://resend.com) — free tier: 100/day, 3000/month
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Time Capsule <onboarding@resend.dev>

# Optional
# DB_PATH=./data/timecapsule.db
# DELIVERY_INTERVAL_MS=30000
# LOG_DIR=./logs
